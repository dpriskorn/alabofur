# Maintainer: Tuncay Bahadır <tuncaybahadir@protonmail.com>
pkgname=alabofur
pkgver=1.0.0
pkgrel=1
pkgdesc="Simple bandwidth shaper with a ufw-like UX"
arch=('any')
url="https://github.com/tuncaybahadir/alabofur"
license=('MIT')
depends=('iproute2' 'kmod')
source=("$pkgname-$pkgver.tar.gz::https://github.com/tuncaybahadir/alabofur/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('d19bda6a8f64c01f2ac1ed6d82e6c2fcffd982450a355db2965b1474fe220f98')

package() {
	cd "$srcdir/$pkgname-$pkgver"
	make PREFIX=/usr DESTDIR="$pkgdir" install
	install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
